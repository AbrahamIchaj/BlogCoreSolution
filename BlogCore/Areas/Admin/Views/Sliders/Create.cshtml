@model BlogCoreSolution.Models.ViewModels.SliderVM;
@{
    ViewData["Title"] = "Crear Slider";
}

<br />
<br />

<h2 class="text-center">Crear un Slider</h2>
<form method="post" asp-action="Create" enctype="multipart/form-data">
    <div class="row px-2 offset-1 border">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="col-10 offset-1 mt-4">
            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="slider.Nombre"></label>
                </div>
                <div class="col-8">
                    <input asp-for="slider.Nombre" class="form-control" placeholder="Ingresa la categoria" />
                    <span asp-validation-for="slider.Nombre" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row mt-2">
                <div class="col-4">
                    <label asp-for="slider.Estado"></label>
                </div>
                <div class="col-8">
                    <select asp-for="slider.Estado" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
          
                    </select>
                    <span asp-validation-for="slider.Estado" class="text-danger"></span>
                </div>

                <div class="form-group row mt-2">
                    <label asp-for="slider.UrlImagen"></label>
                </div>
                <div class="col-8">
                    <input type="file" class="form-control" name="archivos" id="subidaArchivo" />
                    <span asp-validation-for="slider.UrlImagen" class="text-danger"></span>
                </div>


                <div class="form-group-row mt-4">
                    <div class="col-8">
                        <partial name="_VistaCrearVolver" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simplemde@1.11.2/dist/simplemde.min.css">
        <script src="https://cdn.jsdelivr.net/npm/simplemde@1.11.2/dist/simplemde.min.js"></script>

        <script>
            new SimpleMDE({ element: document.getElementById("Contenido") });
        </script>
    }
}
